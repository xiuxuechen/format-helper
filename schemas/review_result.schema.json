{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://format-helper.local/schemas/review_result.schema.json",
  "title": "Review Result",
  "description": "format-helper v3 二轮复核任务结果契约。",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "task_id",
    "task_name",
    "status",
    "checked_at",
    "evidence",
    "issues"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "task_id": {
      "type": "string",
      "pattern": "^T0[1-6]$"
    },
    "task_name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "passed_with_warnings",
        "blocked"
      ]
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "issue_id",
          "severity",
          "description"
        ]
      }
    }
  }
}
