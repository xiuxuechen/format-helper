{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://format-helper.local/schemas/repair_plan.schema.json",
  "title": "Repair Plan",
  "description": "format-helper v3 修复计划契约。YAML 产物按该结构表达。",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "repair_plan_id",
    "created_at",
    "based_on_snapshot",
    "rule_profile",
    "source_docx",
    "working_docx",
    "output_docx",
    "actions",
    "manual_review_items",
    "execution_order",
    "post_repair"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "repair_plan_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "based_on_snapshot": {
      "type": "string",
      "minLength": 1
    },
    "rule_profile": {
      "type": "object",
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_docx": {
      "type": "string",
      "minLength": 1
    },
    "working_docx": {
      "type": "string",
      "minLength": 1
    },
    "output_docx": {
      "type": "string",
      "minLength": 1
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "manual_review_items": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "execution_order": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "post_repair": {
      "type": "object"
    }
  },
  "$defs": {
    "action": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "action_id",
        "source_issue_ids",
        "action_type",
        "target",
        "confidence",
        "semantic_evidence",
        "auto_fix_policy",
        "risk_level",
        "status"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "minLength": 1
        },
        "source_issue_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "action_type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "object",
          "required": [
            "element_id"
          ],
          "properties": {
            "element_id": {
              "type": "string",
              "minLength": 1
            },
            "expected_role": {
              "type": "string"
            }
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "semantic_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "auto_fix_policy": {
          "type": "string",
          "enum": [
            "auto-fix",
            "manual-review",
            "audit-only"
          ]
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "executed",
            "skipped",
            "blocked"
          ]
        }
      }
    }
  }
}
