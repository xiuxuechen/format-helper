{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/format-helper/schemas/reporting-result.schema.json",
  "title": "Reporting Result",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_id",
    "schema_version",
    "contract_version",
    "run_id",
    "reporting_id",
    "status",
    "final_acceptance_path",
    "final_acceptance_sha256",
    "final_acceptance_size_bytes",
    "post_acceptance_manifest_ref",
    "reporting_manifest_ref",
    "report_artifacts",
    "warnings",
    "blockers",
    "generated_at"
  ],
  "properties": {
    "schema_id": {
      "const": "reporting-result"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "contract_version": {
      "const": "v4"
    },
    "run_id": {},
    "reporting_id": {},
    "status": {
      "enum": [
        "done",
        "waiting_user",
        "blocked",
        "accepted",
        "accepted_with_warnings",
        "passed",
        "passed_with_warnings",
        "failed"
      ]
    },
    "final_acceptance_path": {},
    "final_acceptance_sha256": {},
    "final_acceptance_size_bytes": {},
    "post_acceptance_manifest_ref": {},
    "reporting_manifest_ref": {},
    "report_artifacts": {},
    "warnings": {},
    "blockers": {},
    "generated_at": {}
  },
  "description": "CODE-005 最小 schema 占位定义。字段级权威以 contracts/format-helper/schemas 为准。",
  "x_code005_minimum_contract": {
    "source": "41_SCHEMA_CONTRACTS.md + SCHEMA_MIN_STRATEGY.md",
    "validates": [
      "required",
      "const",
      "enum",
      "semver",
      "canonical_alias",
      "unknown_enum_blocking",
      "path_negative_examples"
    ],
    "trace_refs": [
      "41-§2",
      "41-§12",
      "50-§3.5"
    ]
  }
}
