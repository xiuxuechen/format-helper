    "workflow_mode",
    "stage",
    "status",
    "input_docx",
    "rule_id",
    "rule_ref",
    "safe_outputs",
    "skill_results",
    "last_result_id",
    "applied_result_id",
    "result_chain_head",
    "evidence_manifest_path",
    "evidence_manifest_generations",
    "final_acceptance_path",
    "reporting_result_path",
