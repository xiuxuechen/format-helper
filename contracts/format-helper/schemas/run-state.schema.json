    "input_docx": {},
    "rule_id": {},
    "rule_ref": {},
    "safe_outputs": {},
    "skill_results": {},
    "last_result_id": {},
    "applied_result_id": {},
    "result_chain_head": {},
    "evidence_manifest_path": {},
    "evidence_manifest_generations": {},
    "final_acceptance_path": {},
    "reporting_result_path": {},
    "blockers": {},
    "next_action": {},
    "updated_at": {}
  },
  "description": "CODE-005 最小 schema 占位定义。字段级权威以 contracts/format-helper/schemas 为准。",
  "x_code005_minimum_contract": {
    "source": "41_SCHEMA_CONTRACTS.md + SCHEMA_MIN_STRATEGY.md",
    "validates": [
      "required",
      "const",
      "enum",
      "semver",
      "canonical_alias",
      "unknown_enum_blocking",
