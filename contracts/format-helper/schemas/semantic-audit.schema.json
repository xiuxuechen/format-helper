{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/format-helper/schemas/semantic-audit.schema.json",
  "title": "Semantic Audit",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_id",
    "schema_version",
    "contract_version",
    "run_id",
    "status",
    "artifact",
    "source_refs",
    "evidence_refs",
    "generated_at"
  ],
  "properties": {
    "schema_id": {
      "const": "semantic-audit"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "contract_version": {
      "const": "format-helper"
    },
    "run_id": {},
    "status": {
      "enum": [
        "done",
        "waiting_user",
        "blocked",
        "accepted",
        "accepted_with_warnings",
        "passed",
        "passed_with_warnings",
        "failed"
      ]
    },
    "artifact": {},
    "source_refs": {},
    "evidence_refs": {},
    "generated_at": {}
  },
  "description": "CODE-005 最小 schema 占位定义。字段级权威以 contracts/format-helper/schemas 为准。",
  "x_code005_minimum_contract": {
    "source": "contracts/format-helper/schemas + contracts/officecli/schemas",
    "validates": [
      "required",
      "const",
      "enum",
      "semver",
      "canonical_alias",
      "unknown_enum_blocking",
      "path_negative_examples"
    ],
    "trace_refs": [
      "format-helper-schema",
      "format-helper-schema",
      "format-helper-test-plan"
    ]
  }
}
