{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/format-helper/schemas/document-snapshot.schema.json",
  "title": "Document Snapshot",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_id",
    "schema_version",
    "contract_version",
    "run_id",
    "status",
    "artifact",
    "source_refs",
    "evidence_refs",
    "generated_at"
  ],
  "properties": {
    "schema_id": {
      "const": "document-snapshot"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "contract_version": {
      "const": "v4"
    },
    "run_id": {},
    "status": {
      "enum": [
        "done",
        "waiting_user",
        "blocked",
        "accepted",
        "accepted_with_warnings",
        "passed",
        "passed_with_warnings",
        "failed"
      ]
    },
    "artifact": {},
    "source_refs": {},
    "evidence_refs": {},
    "generated_at": {},
    "paragraphs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ParagraphSnapshot"
      }
    },
    "tables": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TableSnapshot"
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SectionSnapshot"
      }
    }
  },
  "$defs": {
    "ParagraphSnapshot": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "resolved_paragraph_format": {
          "$ref": "#/$defs/ResolvedFormatObject"
        },
        "resolved_run_format": {
          "$ref": "#/$defs/ResolvedFormatObject"
        },
        "runs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "resolved_run_format": {
                "$ref": "#/$defs/ResolvedFormatObject"
              }
            }
          }
        }
      }
    },
    "TableSnapshot": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cells": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "paragraphs": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/TableCellParagraphSnapshot"
                }
              }
            }
          }
        }
      }
    },
    "TableCellParagraphSnapshot": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "fact_id",
        "fact_kind",
        "locator"
      ],
      "properties": {
        "fact_id": {
          "type": "string"
        },
        "fact_kind": {
          "const": "table_cell_paragraph"
        },
        "locator": {
          "type": "object",
          "additionalProperties": true
        },
        "resolved_paragraph_format": {
          "$ref": "#/$defs/ResolvedFormatObject"
        },
        "resolved_run_format": {
          "$ref": "#/$defs/ResolvedFormatObject"
        },
        "runs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "resolved_run_format": {
                "$ref": "#/$defs/ResolvedFormatObject"
              }
            }
          }
        }
      }
    },
    "SectionSnapshot": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "fact_id",
        "fact_kind",
        "section_index",
        "locator",
        "page_setup"
      ],
      "properties": {
        "fact_id": {
          "type": "string"
        },
        "fact_kind": {
          "const": "page_setup"
        },
        "section_index": {
          "type": "integer",
          "minimum": 1
        },
        "locator": {
          "type": "object",
          "additionalProperties": true
        },
        "page_setup": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "page_orientation",
            "page_width_twips",
            "page_height_twips",
            "margin_top_cm",
            "margin_bottom_cm",
            "margin_left_cm",
            "margin_right_cm",
            "header_distance_cm",
            "footer_distance_cm",
            "page_number_format"
          ],
          "properties": {
            "page_orientation": {
              "type": "string"
            },
            "page_width_twips": {
              "type": [
                "integer",
                "null"
              ]
            },
            "page_height_twips": {
              "type": [
                "integer",
                "null"
              ]
            },
            "margin_top_cm": {
              "type": [
                "number",
                "null"
              ]
            },
            "margin_bottom_cm": {
              "type": [
                "number",
                "null"
              ]
            },
            "margin_left_cm": {
              "type": [
                "number",
                "null"
              ]
            },
            "margin_right_cm": {
              "type": [
                "number",
                "null"
              ]
            },
            "header_distance_cm": {
              "type": [
                "number",
                "null"
              ]
            },
            "footer_distance_cm": {
              "type": [
                "number",
                "null"
              ]
            },
            "page_number_format": {
              "type": "string"
            }
          }
        }
      }
    },
    "ResolvedFormatValue": {
      "oneOf": [
        {
          "type": [
            "string",
            "number",
            "boolean",
            "null"
          ]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "value",
            "source"
          ],
          "properties": {
            "value": {
              "type": [
                "string",
                "number",
                "boolean",
                "null"
              ]
            },
            "source": {
              "enum": [
                "direct",
                "style_inherit",
                "doc_defaults",
                "theme",
                "word_ui_default",
                "unresolved",
                "legacy"
              ]
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      ]
    },
    "ResolvedFormatObject": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/ResolvedFormatValue"
      }
    }
  },
  "description": "CODE-005 最小 schema 占位定义。CODE-013 扩展 resolved_* 可使用带来源对象；字段级权威以 contracts/format-helper/schemas 与 SLOT_CONTRACT_DESIGN.md §6 为准。",
  "x_code005_minimum_contract": {
    "source": "41_SCHEMA_CONTRACTS.md + SCHEMA_MIN_STRATEGY.md",
    "validates": [
      "required",
      "const",
      "enum",
      "semver",
      "canonical_alias",
      "unknown_enum_blocking",
      "path_negative_examples"
    ],
    "trace_refs": [
      "41-§2",
      "41-§12",
      "50-§3.5"
    ]
  }
}
