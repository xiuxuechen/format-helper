{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/format-helper/schemas/final-acceptance.schema.json",
  "title": "Final Acceptance",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_id",
    "schema_version",
    "contract_version",
    "run_id",
    "acceptance_type",
    "status",
    "skill_results",
    "evidence_manifest_path",
    "evidence_manifest_sha256",
    "evidence_manifest_size_bytes",
    "manual_review_summary",
    "warnings",
    "blockers",
    "blocking_categories",
    "allowed_warning_categories",
    "evaluated_at"
  ],
  "properties": {
    "schema_id": {
      "const": "final-acceptance"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "contract_version": {
      "const": "format-helper"
    },
    "run_id": {},
    "acceptance_type": {},
    "status": {
      "enum": [
        "done",
        "waiting_user",
        "blocked",
        "accepted",
        "accepted_with_warnings",
        "passed",
        "passed_with_warnings",
        "failed"
      ]
    },
    "skill_results": {},
    "evidence_manifest_path": {},
    "evidence_manifest_sha256": {},
    "evidence_manifest_size_bytes": {},
    "manual_review_summary": {},
    "warnings": {},
    "blockers": {},
    "blocking_categories": {},
    "allowed_warning_categories": {},
    "evaluated_at": {}
  },
  "description": "CODE-005 最小 schema 占位定义。字段级权威以 contracts/format-helper/schemas 为准。",
  "x_code005_minimum_contract": {
    "source": "contracts/format-helper/schemas + contracts/officecli/schemas",
    "validates": [
      "required",
      "const",
      "enum",
      "semver",
      "canonical_alias",
      "unknown_enum_blocking",
      "path_negative_examples"
    ],
    "trace_refs": [
      "format-helper-schema",
      "format-helper-schema",
      "format-helper-test-plan"
    ]
  }
}
